# De Trouwvideograaf Blog Generator – Configuratie
# Kopieer dit bestand naar .env en vul de waarden in

# ─── VERPLICHT ───────────────────────────────────────────────────────────────
# Claude API key van console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...

# ─── OPTIONEEL ───────────────────────────────────────────────────────────────
# Claude model (standaard: haiku = goedkoopst, ~€0.002/artikel)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Pad naar de blog map (standaard: bovenliggende map)
# BLOG_DIR=/Users/johndejong/detrouwvideograaf-blog

# GitHub repo URL
# GITHUB_REPO=https://github.com/johnquote/detrouwvideograaf-blog.git

# ─── EMAIL (optioneel) ───────────────────────────────────────────────────────
# Zet EMAIL_ENABLED=true om dagelijkse emails te ontvangen
EMAIL_ENABLED=false

# Jouw Gmail adres
EMAIL_FROM=jouw@gmail.com
EMAIL_TO=jouw@gmail.com

# Gmail App Password (NIET je normale wachtwoord!)
# Aanmaken op: myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
